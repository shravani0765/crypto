   sudo apt install python3-scapy -y
   # OR
   pip3 install scapy

CODE (save as ethernet_ip_tcp.py):
------------------------------------
   from scapy.all import *

   # Step 1: Create an IP layer (defaults: src=your IP, dst=127.0.0.1, TTL=64)
   ip_layer = IP()

   # Step 2: Create a TCP layer (defaults: sport=random, dport=80, flags=S)
   tcp_layer = TCP()

   # Step 3: Stack IP on top of TCP
   ip_tcp_packet = ip_layer / tcp_layer

   # Step 4: Wrap the IP/TCP packet inside an Ethernet frame
   # Ether() defaults: dst=ff:ff:ff:ff:ff:ff, src=your MAC, type=0x0800(IPv4)
   frame = Ether() / ip_tcp_packet

   # Step 5: Display all fields of the complete frame
   print("========== Full Frame Details ==========")
   frame.show()

   # Step 6: Optionally show a one-line summary
   print("\n========== Summary ==========")
   print(frame.summary())

